#!/usr/bin/env python3
"""
exocomp-fixture: Crashable fixture service for systemd recovery integration tests.

This daemon serves a health HTTP endpoint and maintains a workload marker file.
Its behaviour is controlled by writing a mode name to the mode file.

Usage:
    exocomp-fixture [--port PORT] [--addr ADDR] [--state-dir DIR]

Environment variables (CLI flags take precedence):
    FIXTURE_PORT      - HTTP bind port          (default: 8877)
    FIXTURE_ADDR      - HTTP bind address       (default: 127.0.0.1)
    FIXTURE_STATE_DIR - state/control directory (default: /run/exocomp-fixture)

Mode control:
    Write one of the following strings to $FIXTURE_STATE_DIR/mode and the
    service will react within its poll interval (default 1 s):

    active          - healthy, normal operation (also the default when file absent)
    degraded        - process stays alive; health endpoint returns {"status":"degraded"}
    failed          - exit immediately with code 1
    flapping        - exit immediately with code 1 (triggers rapid restart cycle)
    restart-failure - exit immediately with code 1 (exhausts systemd StartLimitBurst)

Health endpoint:
    GET http://<addr>:<port>/health
    200 {"status":"ok"}      when mode is active (or file absent)
    503 {"status":"degraded"} when mode is degraded
    404                      for all other paths

Workload marker:
    $FIXTURE_STATE_DIR/workload.marker is written with an epoch timestamp every
    poll cycle, proving the process is alive and doing work.
"""

import argparse
import json
import logging
import os
import signal
import sys
import threading
import time
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path

# Modes that cause the process to exit immediately with a nonzero code.
EXIT_MODES = frozenset({"failed", "flapping", "restart-failure"})

LOG_FORMAT = "%(asctime)s exocomp-fixture [%(levelname)s] %(message)s"


# ---------------------------------------------------------------------------
# Shared state
# ---------------------------------------------------------------------------

class FixtureState:
    """Thread-safe container for the current service mode."""

    def __init__(self, mode: str = "active") -> None:
        self._mode = mode
        self._lock = threading.Lock()

    def get(self) -> str:
        with self._lock:
            return self._mode

    def set(self, mode: str) -> None:
        with self._lock:
            self._mode = mode


# ---------------------------------------------------------------------------
# HTTP handler
# ---------------------------------------------------------------------------

def _make_handler_class(state: FixtureState) -> type:
    """Return a BaseHTTPRequestHandler subclass that closes over *state*."""

    class _HealthHandler(BaseHTTPRequestHandler):
        _state = state

        # Silence the default "GET /health HTTP/1.1 200 -" lines so systemd
        # journal stays readable during test runs.
        def log_message(self, fmt, *args) -> None:  # type: ignore[override]
            pass

        def do_GET(self) -> None:  # type: ignore[override]
            if self.path == "/health":
                current_mode = self._state.get()
                if current_mode == "degraded":
                    code = 503
                    body = json.dumps({"status": "degraded"}).encode()
                else:
                    code = 200
                    body = json.dumps({"status": "ok"}).encode()

                self.send_response(code)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            else:
                self.send_response(404)
                self.end_headers()

    return _HealthHandler


# ---------------------------------------------------------------------------
# Marker helpers
# ---------------------------------------------------------------------------

def _update_marker(marker_path: Path) -> None:
    """Atomically update the workload marker with the current epoch timestamp."""
    marker_path.parent.mkdir(parents=True, exist_ok=True)
    tmp = marker_path.with_suffix(".marker.tmp")
    tmp.write_text(f"{time.time():.6f}\n", encoding="ascii")
    tmp.replace(marker_path)


def _read_mode(mode_path: Path) -> str:
    """Return the current mode from the mode file, defaulting to 'active'."""
    try:
        return mode_path.read_text(encoding="ascii").strip()
    except OSError:
        return "active"


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(
        description="Crashable fixture service for systemd recovery tests",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.environ.get("FIXTURE_PORT", "8877")),
        help="HTTP bind port (env: FIXTURE_PORT, default: 8877)",
    )
    parser.add_argument(
        "--addr",
        default=os.environ.get("FIXTURE_ADDR", "127.0.0.1"),
        help="HTTP bind address (env: FIXTURE_ADDR, default: 127.0.0.1)",
    )
    parser.add_argument(
        "--state-dir",
        default=os.environ.get("FIXTURE_STATE_DIR", "/run/exocomp-fixture"),
        help="State/control directory (env: FIXTURE_STATE_DIR, default: /run/exocomp-fixture)",
    )
    parser.add_argument(
        "--poll-interval",
        type=float,
        default=float(os.environ.get("FIXTURE_POLL_INTERVAL", "1.0")),
        help="Mode-file poll interval in seconds (env: FIXTURE_POLL_INTERVAL, default: 1.0)",
    )

    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO, format=LOG_FORMAT)
    log = logging.getLogger("exocomp-fixture")

    state_dir = Path(args.state_dir)
    mode_path = state_dir / "mode"
    marker_path = state_dir / "workload.marker"

    # --- Read initial mode ------------------------------------------------
    initial_mode = _read_mode(mode_path)
    log.info("starting with mode=%s", initial_mode)

    if initial_mode in EXIT_MODES:
        log.warning("mode '%s' requires immediate exit (code 1)", initial_mode)
        sys.exit(1)

    # --- Shared state & HTTP server ----------------------------------------
    state = FixtureState(mode=initial_mode)

    handler_class = _make_handler_class(state)
    try:
        server = HTTPServer((args.addr, args.port), handler_class)
    except OSError as exc:
        log.error("cannot bind %s:%d — %s", args.addr, args.port, exc)
        sys.exit(1)

    log.info(
        "health endpoint: http://%s:%d/health  marker: %s",
        args.addr,
        args.port,
        marker_path,
    )

    # Ensure state directory exists before writing the marker.
    state_dir.mkdir(parents=True, exist_ok=True)

    # --- Signal handling ---------------------------------------------------
    shutdown_event = threading.Event()

    def _handle_signal(signum: int, _frame: object) -> None:
        log.info("received signal %d, shutting down", signum)
        shutdown_event.set()

    signal.signal(signal.SIGTERM, _handle_signal)
    signal.signal(signal.SIGINT, _handle_signal)

    # --- Start HTTP server thread ------------------------------------------
    server_thread = threading.Thread(
        target=lambda: server.serve_forever(poll_interval=0.25),
        name="http-server",
        daemon=True,
    )
    server_thread.start()

    # --- Main loop ---------------------------------------------------------
    exit_code = 0
    try:
        while not shutdown_event.is_set():
            # Update the workload marker so callers can detect live activity.
            try:
                _update_marker(marker_path)
            except OSError as exc:
                log.warning("marker write failed: %s", exc)

            # Poll for mode changes.
            new_mode = _read_mode(mode_path)
            current_mode = state.get()
            if new_mode != current_mode:
                log.info("mode transition: %s → %s", current_mode, new_mode)
                if new_mode in EXIT_MODES:
                    log.warning("exit mode '%s', stopping with code 1", new_mode)
                    exit_code = 1
                    shutdown_event.set()
                    break
                state.set(new_mode)

            shutdown_event.wait(timeout=args.poll_interval)
    finally:
        log.info("shutting down HTTP server")
        server.shutdown()
        server_thread.join(timeout=5.0)
        try:
            marker_path.unlink(missing_ok=True)
        except OSError as exc:
            log.debug("marker cleanup: %s", exc)
        log.info("exocomp-fixture stopped (exit_code=%d)", exit_code)

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
